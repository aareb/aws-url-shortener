{
  "name": "url-shortener",
  "version": "1.0.0",
  "type": "module",
  "description": "AWS URL Shortener Lambda function",
  "main": "index.js",
  "scripts": {
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:ci": "jest --coverage --no-coverage-on-line --ci",
    "lint": "eslint .",
    "format": "prettier --write .",
    "build": "npm install --production && zip -r ../terraform/lambda.zip .",
    "dev": "node index.js"
  },
  "keywords": [
    "aws",
    "lambda",
    "url-shortener",
    "serverless"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.500.0",
    "@aws-sdk/lib-dynamodb": "^3.500.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "index.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}

